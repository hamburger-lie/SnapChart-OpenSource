# ========================================
# 数据解析与图表可视化系统 - 环境变量模板
# 复制此文件为 .env 并按需修改
# ========================================

APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========================================
# Agent OpenAPI 专属配置
# ========================================
# ⚠️ 生产环境必须替换为强随机字符串（推荐 32 位以上）
AGENT_API_KEY=your-secret-api-key-here
# ⚠️ 改为线上前端域名（用于拼接 shareUrl）
FRONTEND_BASE_URL=http://your-domain.com
