# ========================================
# SnapChart - Environment Variables Template
# Copy this file to .env and modify as needed
# ========================================

# Environment: dev (allows weak config) / prod (enforces validation)
ENVIRONMENT=dev

APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# Database path (use absolute path for Docker volume mounts)
DATABASE_URL=sqlite+aiosqlite:///./data/styles.db

# CORS origins whitelist (comma separated)
# WARNING: Remove localhost entries in production!
CORS_ORIGINS=http://localhost:5174,http://localhost:3000

# ========================================
# Agent OpenAPI Configuration
# ========================================
# WARNING: Must replace with strong random string in production (32+ chars)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Note: Database stores SHA-256 hash of this key, not plaintext
AGENT_API_KEY=your-secret-api-key-here

# WARNING: Change to actual production domain (include protocol https://)
FRONTEND_BASE_URL=http://your-domain.com
